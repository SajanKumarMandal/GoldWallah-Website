NODE_ENV=development
PORT=5000
FRONTEND_ORIGIN=http://localhost:5173
FRONTEND_URL=http://localhost:5173
BACKEND_PUBLIC_URL=http://localhost:5000
API_VERSION=v1
DATABASE_URL=postgres://postgres:postgres@localhost:5432/goldwallah
JWT_ACCESS_SECRET=replace_with_user_jwt_secret
JWT_REFRESH_SECRET=replace_with_user_refresh_secret
AUTH_COOKIE_DOMAIN=
KYC_ENCRYPTION_KEY=replace_with_64_character_hex_key
KYC_IDENTITY_HASH_SECRET=replace_with_32_plus_character_identity_hash_secret
PRIVATE_MEDIA_SIGNING_SECRET=replace_with_private_media_signing_secret
PG_SSL_CA_FILE=path_to_provider_ca_certificate.pem
PG_SSL_CA=
ADMIN_JWT_ACCESS_SECRET=replace_with_admin_jwt_secret
ADMIN_ACCESS_TOKEN_TTL=15m
ADMIN_REFRESH_TOKEN_TTL_DAYS=7
ADMIN_MFA_REQUIRED=false
ADMIN_SEED_EMAIL=admin@example.com
ADMIN_SEED_PASSWORD=replace_with_temporary_strong_password
ADMIN_SEED_MFA_SECRET=replace_with_base32_totp_secret_for_first_admin
ADMIN_LOGIN_MAX_ATTEMPTS=5
ADMIN_LOGIN_LOCK_MINUTES=15
UPLOAD_STORAGE_PROVIDER=cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
OTP_PROVIDER=mock
OTP_EXPIRY_MINUTES=5
OTP_RESEND_COOLDOWN_SECONDS=60
MSG91_AUTH_KEY=
MSG91_TEMPLATE_ID=
MSG91_SENDER_ID=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_PHONE=
