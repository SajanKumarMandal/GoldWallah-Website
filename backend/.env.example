NODE_ENV=development
PORT=5000
FRONTEND_ORIGIN=http://localhost:5173
FRONTEND_URL=http://localhost:5173
BACKEND_PUBLIC_URL=http://localhost:5000
API_VERSION=v1

DATABASE_URL=postgres://postgres:postgres@localhost:5432/goldwallah
PG_SSL_CA_FILE=
PG_SSL_CA=

REDIS_URL=redis://:goldwallah-local-redis-change-me@127.0.0.1:6379/0
BULLMQ_WORKER_ENABLED=true
NOTIFICATION_QUEUE_CONCURRENCY=5
NOTIFICATION_STREAM_HEARTBEAT_SECONDS=25

JWT_ACCESS_SECRET=replace_with_user_jwt_secret_32_plus_chars
JWT_REFRESH_SECRET=replace_with_user_refresh_secret_32_plus_chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
AUTH_COOKIE_DOMAIN=

KYC_ENCRYPTION_KEY=replace_with_64_character_hex_key
KYC_IDENTITY_HASH_SECRET=replace_with_32_plus_character_identity_hash_secret
PRIVATE_MEDIA_SIGNING_SECRET=replace_with_private_media_signing_secret_32_plus_chars

ADMIN_JWT_ACCESS_SECRET=replace_with_admin_jwt_secret_32_plus_chars
ADMIN_ACCESS_TOKEN_TTL=15m
ADMIN_REFRESH_TOKEN_TTL_DAYS=7
ADMIN_MFA_REQUIRED=false
ADMIN_SEED_EMAIL=admin@example.com
ADMIN_SEED_PASSWORD=replace_with_temporary_strong_password
ADMIN_SEED_MFA_SECRET=replace_with_base32_totp_secret_for_first_admin
ADMIN_LOGIN_MAX_ATTEMPTS=5
ADMIN_LOGIN_LOCK_MINUTES=15

UPLOAD_STORAGE_PROVIDER=local
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=

OTP_PROVIDER=mock
OTP_EXPIRY_MINUTES=5
OTP_RESEND_COOLDOWN_SECONDS=60
OTP_RATE_LIMIT_HASH_SECRET=replace_with_32_plus_character_otp_rate_hash_secret
MSG91_AUTH_KEY=
MSG91_TEMPLATE_ID=
MSG91_SENDER_ID=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_VERIFY_SERVICE_SID=
TWILIO_FROM_PHONE=
